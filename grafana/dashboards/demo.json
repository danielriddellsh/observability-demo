{
  "title": "Overview — Observability Demo",
  "uid": "obs-demo",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["overview", "observability-demo"],
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "links": [
            {
              "title": "Browse traces for this time window →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"nativeSearch\",\"serviceName\":\"api\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{http_response_status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "View error traces in Tempo →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceql\",\"query\":\"{ status = error }\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Request Latency",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le) (rate(http_request_duration_seconds_bucket{http_route=\"/order\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "exemplar": true
        }
      ],
      "options": {
        "yAxis": { "unit": "s", "decimals": 2 },
        "color": { "scheme": "Spectral", "mode": "scheme", "reverse": true },
        "exemplars": { "color": "rgba(255, 0, 255, 0.7)" },
        "tooltip": { "show": true, "yHistogram": true }
      }
    },
    {
      "id": 4,
      "title": "p99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, span_name, service) (rate(traces_spanmetrics_latency_bucket{span_name=~\"validate-input|cache.check|db.lookup|compute\"}[1m])))",
          "legendFormat": "{{service}} / {{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "links": [
            {
              "title": "View db.lookup traces in Tempo →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"nativeSearch\",\"serviceName\":\"worker\",\"spanName\":\"db.lookup\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Service Map",
      "type": "nodeGraph",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 9 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "serviceMap",
          "serviceMapQuery": "{}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache hit ratio",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(worker_cache_operations_total{result=\"hit\"}[1m])) / sum(rate(worker_cache_operations_total[1m]))",
          "legendFormat": "hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    }
  ]
}
