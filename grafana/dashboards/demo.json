{
  "title": "Observability Demo",
  "uid": "obs-demo",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "links": [
            {
              "title": "Browse traces for this time window →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"nativeSearch\",\"serviceName\":\"api\",\"spanName\":\"\",\"search\":\"\",\"minDuration\":\"\",\"maxDuration\":\"\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{http_response_status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "View error traces in Tempo →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceql\",\"query\":\"{ status = error }\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "End-to-end Request Latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{http_route=\"/order\"}[1m]))) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{http_route=\"/order\"}[1m]))) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{http_route=\"/order\"}[1m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "links": [
            {
              "title": "View slow traces in Tempo (>500ms) →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"nativeSearch\",\"serviceName\":\"api\",\"spanName\":\"\",\"search\":\"\",\"minDuration\":\"500ms\",\"maxDuration\":\"\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "p99 Latency by Span — spot the outlier",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, span_name, service) (rate(traces_spanmetrics_latency_bucket{span_name=~\"validate-input|cache.check|db.lookup|compute\"}[1m])))",
          "legendFormat": "{{service}} / {{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "links": [
            {
              "title": "View db.lookup traces in Tempo →",
              "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"nativeSearch\",\"serviceName\":\"worker\",\"spanName\":\"db.lookup\",\"search\":\"\",\"minDuration\":\"\",\"maxDuration\":\"\",\"limit\":20}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": false
            }
          ]
        }
      }
    }
  ]
}
